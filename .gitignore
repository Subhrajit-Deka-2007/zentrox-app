# --- SECRETS & CONFIG ---
# Never push your database credentials, JWT secrets, or API keys
.env

# --- DEPENDENCIES ---
# node_modules is huge; others will download it via 'npm install'
node_modules/

# --- PROJECT SPECIFIC ---
# You mentioned you don't want to push the lock file
package-lock.json

# If you store user-uploaded images locally, don't push them to GitHub
server/uploads/

# --- LOGS ---
# Keeps your repo clean from debug logs generated by morgan or rotating-file-stream
# --- LOGS ---
# This ignores the entire logs folder and everything inside it
logs/
server/logs/ 

# Just in case they are generated in the root
access/
combined/
errors/

# --- SYSTEM FILES ---
# Junk files created by Mac or Windows
.DS_Store
Thumbs.db